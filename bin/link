#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_DIR="$HOME/.dotfiles-backups/$TIMESTAMP"
BACKUP_CREATED=0

backup_target() {
  local target="$1"
  local backup_name

  backup_name="$(basename "$target")"

  if [[ $BACKUP_CREATED -eq 0 ]]; then
    mkdir -p "$BACKUP_DIR"
    BACKUP_CREATED=1
  fi

  mv "$target" "$BACKUP_DIR/$backup_name"
  echo "Backed up $target -> $BACKUP_DIR/$backup_name"
}

link_file() {
  local source="$1"
  local target="$2"
  local target_dir

  target_dir="$(dirname "$target")"
  mkdir -p "$target_dir"

  if [[ -L "$target" ]]; then
    if [[ "$(readlink "$target")" == "$source" ]]; then
      echo "Unchanged: $target"
      return 0
    fi

    backup_target "$target"
  elif [[ -e "$target" ]]; then
    backup_target "$target"
  fi

  ln -sfn "$source" "$target"
  echo "Linked: $target -> $source"
}

link_file "$ROOT/zsh/zshrc" "$HOME/.zshrc"
link_file "$ROOT/git/gitconfig" "$HOME/.gitconfig"
link_file "$ROOT/git/gitignore" "$HOME/.gitignore"

echo "Dotfile linking complete."
